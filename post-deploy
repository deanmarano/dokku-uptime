#!/usr/bin/env bash
set -eo pipefail
[[ $DOKKU_TRACE ]] && set -x

source "$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)/functions"

APP="$1"

if fn-uptime-is-disabled "$APP"; then
  dokku_log_verbose "Uptime monitoring disabled for $APP, skipping"
  exit 0
fi

MONITOR_ID=$(fn-uptime-get-monitor-id "$APP")
if [[ -n "$MONITOR_ID" ]]; then
  dokku_log_verbose "Uptime monitor already exists for $APP (ID: $MONITOR_ID)"
  exit 0
fi

fn-uptime-create-monitor "$APP"
