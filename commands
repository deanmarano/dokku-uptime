#!/usr/bin/env bash
set -eo pipefail
[[ $DOKKU_TRACE ]] && set -x

PLUGIN_BASE_PATH="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

case "$1" in
  help | uptime:help)
    help_content_func() {
      declare desc="return uptime plugin help content"
      cat <<help_content
    uptime <app>, Show uptime monitoring status for an app
    uptime:status <app>, Show uptime monitoring status for an app
    uptime:enable <app>, Enable uptime monitoring for an app
    uptime:disable <app>, Disable uptime monitoring for an app
    uptime:discover, Scan all apps and create missing monitors
    uptime:set [--global] <key> <value>, Set uptime configuration
help_content
    }

    if [[ $1 == "uptime:help" ]]; then
      echo -e "Usage: dokku uptime[:COMMAND] [<app>]"
      echo ""
      echo "Manage Uptime Kuma monitors for dokku apps."
      echo ""
      echo "Additional commands:"
      help_content_func | sort | column -c2 -t -s,
      echo ""
    else
      help_content_func
    fi
    ;;

  *)
    exit "$DOKKU_NOT_IMPLEMENTED_EXIT"
    ;;
esac
